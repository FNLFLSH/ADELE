{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "adele-shell",
  "version": "0.1.0",
  "identifier": "com.edge.adele-shell",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ADELE",
        "label": "main",
        "width": 480,
        "height": 520,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
